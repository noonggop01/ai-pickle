---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../site.config';

const title = 'Contact';
const description = `Get in touch with ${SITE.name}.`;
---

<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>
    For questions, corrections, or business inquiries, email us at
    <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.
  </p>
  <p>We read every message and try to respond within a few business days.</p>
</BaseLayout>
