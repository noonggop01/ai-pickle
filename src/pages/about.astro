---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../site.config';

const title = 'About';
const description = `About ${SITE.name} — who we are and how we test the AI tools we review.`;
---

<BaseLayout title={title} description={description}>
  <h1>About {SITE.name}</h1>

  <p>
    {SITE.name} publishes hands-on reviews and comparisons of AI writing, image, video,
    and productivity tools. We focus on practical questions readers actually have —
    which tool is worth paying for, how tools compare on real tasks, and where the
    free tiers fall short — rather than rewriting press releases.
  </p>

  <h2>How we work</h2>
  <p>
    Drafts are researched and written with AI assistance, then reviewed and edited by
    a human before publishing. Every review is checked for accuracy and updated when
    a tool changes significantly. We do not accept payment in exchange for a positive
    review.
  </p>

  <h2>Advertising</h2>
  <p>
    This site is supported by display advertising (including Google AdSense) and may,
    in the future, include affiliate links clearly marked as such. Advertising and
    affiliate relationships never determine our conclusions.
  </p>

  <h2>Contact</h2>
  <p>
    Questions, corrections, or tips? Reach out on the <a href="/contact">contact page</a>.
  </p>
</BaseLayout>
